<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivWarning"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@android:drawable/stat_sys_warning"
        app:tint="#D32F2F"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTituloError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Límite de UV excedido"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:fontFamily="@font/finland_rounded_bold"
        app:layout_constraintTop_toBottomOf="@id/ivWarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDetalleCum"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Tu CUM es 0.0, permitiendo un máximo de 16 UV."
        android:textColor="#666666"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloError"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/tvDetalleCum">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INTENTADO"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvUvIntentadas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24 UV"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:fontFamily="@font/finland_rounded_bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MÁXIMO"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvUvMaximas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="16 UV"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                android:fontFamily="@font/finland_rounded_bold" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnEntendido"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#062451"
        android:text="REVISAR MI SELECCIÓN"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="@font/finland_rounded_bold"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutStats" />

</androidx.constraintlayout.widget.ConstraintLayout>