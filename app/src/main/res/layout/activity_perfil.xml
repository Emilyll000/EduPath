<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgBackgroundPerfil"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/perfil" />

    <ScrollView
        android:id="@+id/scrollPerfil"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/includeBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvTituloPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="100dp"
                android:text="Mi perfil"
                android:textColor="@color/text_dark"
                android:textSize="36sp"
                android:fontFamily="@font/finland_rounded_bold"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/layoutPerfilPrincipal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvTituloPerfil"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:layout_width="94dp"
                    android:layout_height="94dp"
                    android:background="@drawable/bg_circle_avatar">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="6dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvAvatarIniciales"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="GM"
                        android:textColor="@color/text_dark"
                        android:textSize="32sp"
                        android:fontFamily="@font/finland_rounded_bold"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/tvNombrePerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="24sp"
                        android:fontFamily="@font/finland_rounded_bold"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:background="@null"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:cursorVisible="false" />

                    <EditText
                        android:id="@+id/tvApellidoPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="26sp"
                        android:fontFamily="@font/finland_rounded_bold"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:background="@null"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:cursorVisible="false" />

                    <TextView
                        android:id="@+id/tvCarreraPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Ingeniería en Ciencias de la Computación"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/finland_rounded_bold"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardCarnet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="28dp"
                android:background="@drawable/bg_profile_info_card"
                android:orientation="vertical"
                android:padding="18dp"
                app:layout_constraintTop_toBottomOf="@id/layoutPerfilPrincipal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carnet"
                    android:textColor="@color/text_dark"
                    android:textSize="17sp"
                    android:fontFamily="@font/finland_rounded_regular"
                    android:textStyle="normal" /> <EditText
                android:id="@+id/tvCarnetPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/finland_rounded_bold"
                android:textStyle="normal"
                android:background="@null"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardCorreo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="28dp"
                android:background="@drawable/bg_profile_info_card"
                android:orientation="vertical"
                android:padding="18dp"
                app:layout_constraintTop_toBottomOf="@id/cardCarnet"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correo"
                    android:textColor="@color/text_dark"
                    android:textSize="17sp"
                    android:fontFamily="@font/finland_rounded_bold"
                    android:textStyle="normal" />

                <TextView
                    android:id="@+id/tvCorreoPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="-"
                    android:fontFamily="@font/finland_rounded_regular"
                    android:textColor="@color/text_dark"
                    android:textStyle="normal"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardPlan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="28dp"
                android:background="@drawable/bg_profile_info_card"
                android:orientation="vertical"
                android:padding="18dp"
                app:layout_constraintTop_toBottomOf="@id/cardCorreo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plan de estudio"
                    android:textColor="@color/text_dark"
                    android:textSize="17sp"
                    android:fontFamily="@font/finland_rounded_bold"
                    android:textStyle="normal" />

                <TextView
                    android:id="@+id/tvPlanPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="-"
                    android:fontFamily="@font/finland_rounded_regular"
                    android:textColor="@color/text_dark"
                    android:textStyle="normal"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/actionButtons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="28dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/cardPlan"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <Button
                    android:id="@+id/btnSalir"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/blue_main"
                    android:text="Cerrar sesión"
                    android:textSize="16sp"
                    android:fontFamily="@font/finland_rounded_bold"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnEditar"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yellow_main"
                    android:text="Editar perfil"
                    android:textSize="16sp"
                    android:fontFamily="@font/finland_rounded_bold"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <include
        android:id="@+id/includeBottomNav"
        layout="@layout/include_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>