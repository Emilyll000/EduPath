<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg">

    <ImageView
        android:id="@+id/imgBackgroundLogin"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/bg_login"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/imgLogoLogin"
        android:layout_width="190dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.22" />

    <EditText
        android:id="@+id/etCarnet"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="22dp"
        android:layout_marginTop="260dp"
        android:layout_marginEnd="22dp"
        android:background="@drawable/bg_input"
        android:hint="Escribe tu carnet"
        android:inputType="text"
        android:paddingStart="20dp"
        android:paddingEnd="14dp"
        android:textColor="@color/text_dark"
        android:textColorHint="#B8B1A6"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogoLogin" />

    <View
        android:id="@+id/barCarnet"
        android:layout_width="10dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_input_text2"
        app:layout_constraintTop_toTopOf="@id/etCarnet"
        app:layout_constraintBottom_toBottomOf="@id/etCarnet"
        app:layout_constraintStart_toStartOf="@id/etCarnet" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPassword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:hintEnabled="false"
        app:passwordToggleEnabled="false"
        app:layout_constraintEnd_toEndOf="@id/etCarnet"
        app:layout_constraintStart_toStartOf="@id/etCarnet"
        app:layout_constraintTop_toBottomOf="@id/etCarnet">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Escribe tu contraseña"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="55dp"
                android:textColor="@color/text_dark"
                android:textColorHint="#B8B1A6"
                android:textSize="16sp" />

            <View
                android:id="@+id/barPassword"
                android:layout_width="10dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/bg_input_text" />

            <ImageButton
                android:id="@+id/btnTogglePassword"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/cerrado" />
        </FrameLayout>

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvLoginLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:fontFamily="@font/finland_rounded_bold"
        android:text="Iniciar Sesión"
        android:textColor="#1F75CA"
        android:textSize="30sp"
        app:layout_constraintStart_toStartOf="@id/etCarnet"
        app:layout_constraintTop_toBottomOf="@id/tilPassword" />

    <ImageButton
        android:id="@+id/btnLogin"
        android:layout_width="150dp"
        android:layout_height="75dp"
        android:layout_marginTop="45dp"
        android:background="@android:color/transparent"
        android:contentDescription="Iniciar sesión"
        android:scaleType="fitEnd"
        android:src="@drawable/bg_forma_rara"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tilPassword" />

    <TextView
        android:id="@+id/tvRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="110dp"
        android:fontFamily="@font/finland_rounded_regular"
        android:text="Regístrate"
        android:textColor="#8BB7DD"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/etCarnet" />

    <TextView
        android:id="@+id/tvRecover"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="110dp"
        android:fontFamily="@font/finland_rounded_regular"
        android:text="Recupera tu contraseña"
        android:textColor="#8BB7DD"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/etCarnet" />

</androidx.constraintlayout.widget.ConstraintLayout>