<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4">
        <TextView android:id="@+id/tvNombreAct" android:layout_width="0dp" android:layout_weight="1.6" android:layout_height="wrap_content" android:padding="8dp" android:fontFamily="@font/finland_rounded_regular" android:textColor="#333333"/>
        <View android:id="@+id/v1" android:layout_width="2dp" android:layout_height="match_parent" android:background="#4476A1" />
        <TextView android:id="@+id/tvNotaAct" android:layout_width="0dp" android:layout_weight="0.8" android:layout_height="wrap_content" android:gravity="center" android:padding="8dp" android:fontFamily="@font/finland_rounded_regular" android:textColor="#333333"/>
        <View android:id="@+id/v2" android:layout_width="2dp" android:layout_height="match_parent" android:background="#4476A1" />
        <TextView android:id="@+id/tvValorAct" android:layout_width="0dp" android:layout_weight="0.8" android:layout_height="wrap_content" android:gravity="center" android:padding="8dp" android:fontFamily="@font/finland_rounded_regular" android:textColor="#333333"/>
        <View android:id="@+id/v3" android:layout_width="2dp" android:layout_height="match_parent" android:background="#4476A1" />
        <TextView android:id="@+id/tvGanadoAct" android:layout_width="0dp" android:layout_weight="0.8" android:layout_height="wrap_content" android:gravity="center" android:padding="8dp" android:fontFamily="@font/finland_rounded_regular" android:textColor="#333333"/>
    </LinearLayout>

    <View android:id="@+id/vH" android:layout_width="match_parent" android:layout_height="2dp" android:background="#4476A1" />
</LinearLayout>