<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvCodigoMateriaInscribible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAT101"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvNombreMateriaInscribible"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:text="Nombre de la Materia"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:fontFamily="@font/finland_rounded_bold"
            app:layout_constraintTop_toBottomOf="@id/tvCodigoMateriaInscribible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvSeleccionMateria" />

        <TextView
            android:id="@+id/tvImportanciaMateria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="ALTA"
            android:textColor="#1A1A1A"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvNombreMateriaInscribible"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvAbreMateria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Habilita 2"
            android:textColor="#888888"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/tvImportanciaMateria"
            app:layout_constraintStart_toEndOf="@id/tvImportanciaMateria"
            app:layout_constraintTop_toTopOf="@id/tvImportanciaMateria" />

        <TextView
            android:id="@+id/tvMatriculaMateria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="#D32F2F"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/tvImportanciaMateria"
            app:layout_constraintStart_toEndOf="@id/tvAbreMateria"
            app:layout_constraintTop_toTopOf="@id/tvImportanciaMateria" />

        <TextView
            android:id="@+id/tvSeleccionMateria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AÑADIR"
            android:textColor="#062451"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvPesoMateria"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>