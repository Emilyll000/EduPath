<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F1E6">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/base" />

    <TextView
        android:id="@+id/tvTituloInscripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="160dp" android:layout_marginHorizontal="24dp"
        android:text="Inscripción"
        android:textColor="#1A1A1A"
        android:textSize="32sp"
        android:fontFamily="@font/finland_rounded_bold"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtituloInscripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="4dp"
        android:text="Selecciona tus materias"
        android:textColor="#666666"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloInscripcion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMateriasInscribibles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtituloInscripcion"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnGuardarInscripcion"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="35dp"
        android:background="@drawable/bg_button_round"
        android:backgroundTint="#8BB7DD" android:text="Guardar inscripción"
        android:textAllCaps="false"
        android:textColor="#FFFFFF" android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>